{
  "manifestVersion": 5,
  "main": "index.html",
  "id": "XiaoLiangRH",
  "name": "小梁RH",
  "version": "2.2.4",
  "host": {
    "minVersion": "25.0.0",
    "app": "PS"
  },
  "entrypoints": [
    {
      "id": "xiaoliangRhPanel",
      "type": "panel",
      "label": {
        "default": "小梁RH"
      },
      "preferredFloatingSize": {
        "height": 400,
        "width": 350
      },
      "preferredDockedSize": {
        "height": 400,
        "width": 350
      },
      "minimumSize": {
        "height": 400,
        "width": 350
      },
      "maximumSize": {
        "height": 9999,
        "width": 9999
      },
      "icons": [
        {
          "path": "icons/icon_24.png",
          "width": 23,
          "height": 23,
          "scale": [1, 2],
          "theme": ["darkest", "dark", "medium"]
        },
        {
          "path": "icons/icon_24.png",
          "width": 23,
          "height": 23,
          "scale": [1, 2],
          "theme": ["lightest", "light"]
        }
      ]
    }
  ],
  "icons": [
    {
      "path": "icons/icon_24.png",
      "width": 23,
      "height": 23,
      "scale": [1, 2],
      "theme": ["darkest", "dark", "medium"],
      "species": ["pluginList"]
    },
    {
      "path": "icons/icon_24.png",
      "width": 23,
      "height": 23,
      "scale": [1, 2],
      "theme": ["lightest", "light"],
      "species": ["pluginList"]
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "allowCodeGenerationFromStrings": true,
    "imaging": {
      "imagePix": "readAndWrite"
    },
    "launchProcess": {
      "extensions": [".cmd", ".exe", ".html", ".jpeg", ".jpg", ".png", ".svg", ".url", ""],
      "schemes": ["https", "http", "file"]
    },
    "network": {
      "domains": "all"
    },
    "webview": {
      "allow": "yes",
      "allowLocalRendering": "yes",
      "enableMessageBridge": "localAndRemote",
      "domains": [
        "all",
        "http://localhost:*",
        "https://localhost:*",
        "ws://localhost:*",
        "http://127.0.0.1:*",
        "https://127.0.0.1:*",
        "ws://127.0.0.1:*"
      ]
    }
  }
}
